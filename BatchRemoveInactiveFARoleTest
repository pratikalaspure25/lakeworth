    // ── Insert: ACR already exists with another role, Authorized Signer is appended
    @isTest
    static void testInsert_ExistingACRWithOtherRole_AuthorizedSignerRoleAppended() {
        Map<String, Account> accounts = getAccounts();
        Account bizPO  = accounts.get('Business PO');
        Account indvRA = accounts.get('Individual RA');
        RecordType faRT = getFinAccRT();
        
        // Pre-create the ACR with a different role so the insert path hits roleContains + appendRole
        AccountContactRelation existingACR = new AccountContactRelation(
            AccountId = bizPO.Id,
            ContactId = indvRA.PersonContactId,
            Roles     = 'Power of Attorney'
        );
        insert existingACR;
        
        insert buildFA('TEST FA Append Role', bizPO.Id, faRT.Id);
        FinServ__FinancialAccount__c fa = [SELECT Id FROM FinServ__FinancialAccount__c WHERE Name = 'TEST FA Append Role' LIMIT 1];
        
        Test.startTest();
        insert new FinServ__FinancialAccountRole__c(
            FinServ__FinancialAccount__c = fa.Id,
            FinServ__RelatedAccount__c   = indvRA.Id,
            FinServ__Role__c             = AUTHORIZED_SIGNER_ROLE
        );
        Test.stopTest();
        
        AccountContactRelation updatedACR = [
            SELECT Roles
            FROM AccountContactRelation
            WHERE AccountId = :bizPO.Id
            AND   ContactId = :indvRA.PersonContactId
            LIMIT 1
        ];
        System.assert(updatedACR.Roles.contains('Authorized Signer'), 'Authorized Signer should be appended to existing roles');
        System.assert(updatedACR.Roles.contains('Power of Attorney'), 'Existing role should be preserved');
    }
    
    // ── Delete: ACR has multiple roles, only Authorized Signer is stripped ─────
    @isTest
    static void testDelete_ACRHasMultipleRoles_OnlyAuthorizedSignerStripped() {
        Map<String, Account> accounts = getAccounts();
        Account bizPO  = accounts.get('Business PO');
        Account indvRA = accounts.get('Individual RA');
        RecordType faRT = getFinAccRT();
        
        // Pre-create ACR with two roles so delete hits the removeRole/update path instead of full delete
        AccountContactRelation existingACR = new AccountContactRelation(
            AccountId = bizPO.Id,
            ContactId = indvRA.PersonContactId,
            Roles     = 'Power of Attorney;Authorized Signer'
        );
        insert existingACR;
        
        insert buildFA('TEST FA Strip Role', bizPO.Id, faRT.Id);
        FinServ__FinancialAccount__c fa = [SELECT Id FROM FinServ__FinancialAccount__c WHERE Name = 'TEST FA Strip Role' LIMIT 1];
        
        FinServ__FinancialAccountRole__c far = new FinServ__FinancialAccountRole__c(
            FinServ__FinancialAccount__c = fa.Id,
            FinServ__RelatedAccount__c   = indvRA.Id,
            FinServ__Role__c             = AUTHORIZED_SIGNER_ROLE
        );
        insert far;
        
        Test.startTest();
        delete far;
        Test.stopTest();
        
        AccountContactRelation updatedACR = [
            SELECT Roles
            FROM AccountContactRelation
            WHERE AccountId = :bizPO.Id
            AND   ContactId = :indvRA.PersonContactId
            LIMIT 1
        ];
        System.assert(!updatedACR.Roles.contains('Authorized Signer'), 'Authorized Signer role should be removed');
        System.assert(updatedACR.Roles.contains('Power of Attorney'), 'Other roles should remain intact');
    }
