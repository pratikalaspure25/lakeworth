    static void testInsert_BusinessPrimaryOwner_IndividualAuthorizedSigner_CreatesACR() {
        Map<String, Account> accounts = getAccounts();
        Account bizPO  = accounts.get('Business PO');
        Account indvRA = accounts.get('Individual RA');
        RecordType faRT = getFinAccRT();
        
        insert buildFA('TEST FA Biz PO Indv RA', bizPO.Id, faRT.Id);
        FinServ__FinancialAccount__c fa = [SELECT Id FROM FinServ__FinancialAccount__c WHERE Name = 'TEST FA Biz PO Indv RA' LIMIT 1];
        
        Test.startTest();
        insert new FinServ__FinancialAccountRole__c(
            FinServ__FinancialAccount__c = fa.Id,
            FinServ__RelatedAccount__c   = indvRA.Id,
            FinServ__Role__c             = AUTHORIZED_SIGNER_ROLE
        );
        Test.stopTest();
        
        List<AccountContactRelation> acrs = [
            SELECT Id, Roles
            FROM AccountContactRelation
            WHERE AccountId = :bizPO.Id
            AND   ContactId = :indvRA.PersonContactId
        ];
        System.assertEquals(1, acrs.size(), 'Expected 1 ACR for business PO and individual authorized signer');
        System.assert(acrs[0].Roles.contains('Authorized Signer'), 'Authorized Signer role not set on ACR');
    }
    
