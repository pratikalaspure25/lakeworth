@IsTest
private class BatchRemoveInactiveFARoleTest {

    private static final Integer STALE_DAYS = 7;

    @TestSetup
    static void setupData() {

        Account acc = new Account(
            Name = 'Test Account',
            BillingCity = 'City',
            BillingCountry = 'United States',
            BillingPostalCode = '12345',
            BillingState = 'State',
            BillingStreet = 'Street'
        );
        insert acc;

        FinServ__FinancialAccount__c fa = new FinServ__FinancialAccount__c(
            Name = 'Test FA',
            FinServ__PrimaryOwner__c = acc.Id,
            FinServ__Status__c = 'Open'
        );
        insert fa;

        List<FinServ__FinancialAccountRole__c> fars = new List<FinServ__FinancialAccountRole__c>();

        // ✅ STALE (should delete)
        fars.add(new FinServ__FinancialAccountRole__c(
            FinServ__FinancialAccount__c = fa.Id,
            FinServ__Role__c = 'Authorized Signer',
            CRM_As_of__c = Date.today().addDays(-10)
        ));

        // ✅ STALE (should delete)
        fars.add(new FinServ__FinancialAccountRole__c(
            FinServ__FinancialAccount__c = fa.Id,
            FinServ__Role__c = 'Authorized Signer',
            CRM_As_of__c = Date.today().addDays(-20)
        ));

        // ❌ PRIMARY OWNER (should NOT delete)
        fars.add(new FinServ__FinancialAccountRole__c(
            FinServ__FinancialAccount__c = fa.Id,
            FinServ__Role__c = 'Primary Owner',
            CRM_As_of__c = Date.today().addDays(-20)
        ));

        // ❌ FRESH (should NOT delete)
        fars.add(new FinServ__FinancialAccountRole__c(
            FinServ__FinancialAccount__c = fa.Id,
            FinServ__Role__c = 'Authorized Signer',
            CRM_As_of__c = Date.today()
        ));

        insert fars;
    }

    // ✅ MAIN TEST (COVERS EVERYTHING)
    @IsTest
    static void testBatchExecution() {

        Test.startTest();
        Database.executeBatch(new BatchRemoveInactiveFARole(), 1); // small batch for better coverage
        Test.stopTest();

        List<FinServ__FinancialAccountRole__c> remaining = [
            SELECT FinServ__Role__c, CRM_As_of__c
            FROM FinServ__FinancialAccountRole__c
        ];

        // Only 2 should remain:
        // 1 Primary Owner + 1 Fresh
        System.assertEquals(2, remaining.size());

        Boolean foundPrimaryOwner = false;
        Boolean foundFresh = false;

        for (FinServ__FinancialAccountRole__c far : remaining) {
            if (far.FinServ__Role__c == 'Primary Owner') {
                foundPrimaryOwner = true;
            }
            if (far.CRM_As_of__c == Date.today()) {
                foundFresh = true;
            }
        }

        System.assert(foundPrimaryOwner, 'Primary Owner should NOT be deleted');
        System.assert(foundFresh, 'Fresh record should remain');
    }

    // ✅ NO RECORDS CASE
    @IsTest
    static void testNoEligibleRecords() {

        List<FinServ__FinancialAccountRole__c> fars = [
            SELECT Id FROM FinServ__FinancialAccountRole__c
        ];

        for (FinServ__FinancialAccountRole__c far : fars) {
            far.CRM_As_of__c = Date.today();
        }
        update fars;

        Test.startTest();
        Database.executeBatch(new BatchRemoveInactiveFARole(), 1);
        Test.stopTest();

        System.assertEquals(
            fars.size(),
            [SELECT COUNT() FROM FinServ__FinancialAccountRole__c]
        );
    }

    // ✅ FINISH METHOD
    @IsTest
    static void testFinish() {

        Test.startTest();
        Database.executeBatch(new BatchRemoveInactiveFARole(), 1);
        Test.stopTest();

        System.assert(true);
    }
}
