@IsTest
private class BatchRemoveInactiveFARoleTest {

    private static final Integer STALE_DAYS = 7;

    @TestSetup
    static void setupData() {

        /* ── Business Account (your same structure) ── */
        Account businessAcct = new Account(
            Name = 'Batch Test Business',
            BKU_CIF_Number__c      = '9876543211',
            Phone                  = '555-555-5551',
            Email__c               = 'bizpo@test.com',
            BKU_TaxID_Encrypted__c = '123456781',
            BillingCity            = 'Business City',
            BillingCountry         = 'United States',
            BillingPostalCode      = '54321',
            BillingState           = 'Florida',
            BillingStreet          = '1 Business Street',
            ShippingCity           = 'Business City',
            ShippingCountry        = 'United States',
            ShippingPostalCode     = '54321',
            ShippingState          = 'Florida',
            ShippingStreet         = '1 Business Street'
        );
        insert businessAcct;

        /* ── Financial Accounts (NO RecordType needed now) ── */
        FinServ__FinancialAccount__c fa1 = new FinServ__FinancialAccount__c(
            Name                     = 'Batch Loan FA',
            FinServ__PrimaryOwner__c = businessAcct.Id,
            FinServ__Status__c       = 'Open'
        );

        FinServ__FinancialAccount__c fa2 = new FinServ__FinancialAccount__c(
            Name                     = 'Batch Bank FA',
            FinServ__PrimaryOwner__c = businessAcct.Id,
            FinServ__Status__c       = 'Open'
        );

        insert new List<FinServ__FinancialAccount__c>{ fa1, fa2 };

        /* ── Financial Account Roles ── */
        insert new List<FinServ__FinancialAccountRole__c>{

            // STALE → should be deleted
            new FinServ__FinancialAccountRole__c(
                FinServ__FinancialAccount__c = fa1.Id,
                FinServ__Role__c             = 'Authorized Signer',
                CRM_As_of__c                 = Date.today().addDays(-(STALE_DAYS + 1))
            ),

            new FinServ__FinancialAccountRole__c(
                FinServ__FinancialAccount__c = fa2.Id,
                FinServ__Role__c             = 'Authorized Signer',
                CRM_As_of__c                 = Date.today().addDays(-30)
            ),

            // FRESH → should remain
            new FinServ__FinancialAccountRole__c(
                FinServ__FinancialAccount__c = fa2.Id,
                FinServ__Role__c             = 'Authorized Signer',
                CRM_As_of__c                 = Date.today()
            )
        };
    }

    /* ─────────────────────────────────────────────
       Test 1: Deletes only stale FARs
       ───────────────────────────────────────────── */
    @IsTest
    static void testBatchDeletesOnlyStaleFARs() {

        Test.startTest();
        Database.executeBatch(new BatchRemoveInactiveFARole(), 200);
        Test.stopTest();

        List<FinServ__FinancialAccountRole__c> remaining = [
            SELECT CRM_As_of__c
            FROM FinServ__FinancialAccountRole__c
        ];

        // ✅ FIX: Proper assertion added
        System.assertEquals(
            1,
            remaining.size(),
            'Only one fresh FAR should remain'
        );

        System.assert(
            remaining[0].CRM_As_of__c >= Date.today().addDays(-STALE_DAYS),
            'Remaining FAR must be fresh'
        );
    }

    /* ─────────────────────────────────────────────
       Test 2: Batch does nothing when no records qualify
       ───────────────────────────────────────────── */
    @IsTest
    static void testBatchWithNoEligibleRecords() {

        List<FinServ__FinancialAccountRole__c> fars = [
            SELECT Id
            FROM FinServ__FinancialAccountRole__c
        ];

        for (FinServ__FinancialAccountRole__c far : fars) {
            far.CRM_As_of__c = Date.today();
        }
        update fars;

        Test.startTest();
        Database.executeBatch(new BatchRemoveInactiveFARole(), 200);
        Test.stopTest();

        System.assertEquals(
            fars.size(),
            [SELECT COUNT() FROM FinServ__FinancialAccountRole__c],
            'No FARs should be deleted when all are fresh'
        );
    }

    /* ─────────────────────────────────────────────
       Test 3: Finish method executes safely
       ───────────────────────────────────────────── */
    @IsTest
    static void testFinishRunsWithoutException() {

        Test.startTest();
        Database.executeBatch(new BatchRemoveInactiveFARole());
        Test.stopTest();

        System.assert(true, 'Batch finish executed successfully');
    }
}
