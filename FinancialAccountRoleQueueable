public without sharing class FinancialAccountRoleQueueable implements Queueable {

    private static final String AUTHORIZED_SIGNER_ROLE   = 'Other - Authorized Signer';
    private static final String ROLE_LABEL               = 'Authorized Signer';
    private static final String TYPE_INDIVIDUAL          = 'Individual';
    private static final String TYPE_BUSINESS            = 'Business';
    private static final String ASSOC_TYPE_PEER          = 'Peer';
    private static final String HELPDESK_EMAIL         = 'crm360helpdesk@bankunited.com';
    private static final Integer MAX_RETRIES           = 3;

    private List<FinServ__FinancialAccountRole__c> insertedFARs;
    private List<FinServ__FinancialAccountRole__c> deletedFARs;
    private Integer retryCount;

    // Constructor
    public FinancialAccountRoleQueueable(
        List<FinServ__FinancialAccountRole__c> insertedFARs,
        List<FinServ__FinancialAccountRole__c> deletedFARs
    ) {
        this(insertedFARs, deletedFARs, 0);
    }

    public FinancialAccountRoleQueueable(
        List<FinServ__FinancialAccountRole__c> insertedFARs,
        List<FinServ__FinancialAccountRole__c> deletedFARs,
        Integer retryCount
    ) {
        this.insertedFARs = insertedFARs;
        this.deletedFARs  = deletedFARs;
        this.retryCount   = retryCount;
    }

    public void execute(QueueableContext context) {
        try {
            if (insertedFARs != null && !insertedFARs.isEmpty()) {
                processInserts(insertedFARs);
            }
            if (deletedFARs != null && !deletedFARs.isEmpty()) {
                processDeletes(deletedFARs);
            }
        } catch (Exception e) {
            sendErrorEmail('Unhandled exception:\n' + e.getMessage() + '\n' + e.getStackTraceString());
        }
    }

    private void processInserts(List<FinServ__FinancialAccountRole__c> farList) {
        Set<Id> farIds = new Map<Id, FinServ__FinancialAccountRole__c>(farList).keySet();

        List<FinServ__FinancialAccountRole__c> enriched = [
            SELECT Id,
                   FinServ__RelatedAccount__c,
                   FinServ__RelatedAccount__r.BKU_Record_Type_Name__c,
                   FinServ__RelatedAccount__r.PersonContactId,
                   FinServ__FinancialAccount__c,
                   FinServ__FinancialAccount__r.FinServ__PrimaryOwner__c,
                   FinServ__FinancialAccount__r.FinServ__PrimaryOwner__r.BKU_Record_Type_Name__c,
                   FinServ__FinancialAccount__r.FinServ__PrimaryOwner__r.PersonContactId
            FROM FinServ__FinancialAccountRole__c
            WHERE Id IN :farIds
        ];

        Map<String, Id> reciprocalRoleMapAcct = getReciprocalRoleIdMap('AccountRole');
        Id authSignerAcctRoleId = reciprocalRoleMapAcct.get(ROLE_LABEL);
        Map<String, Id> reciprocalRoleMapCont = getReciprocalRoleIdMap('ContactRole');
        Id authSignerContRoleId = reciprocalRoleMapCont.get(ROLE_LABEL);

        List<FARContext> contexts = buildContexts(enriched);

        Set<Id> acrAccountIds  = new Set<Id>();
        Set<Id> acrContactIds  = new Set<Id>();
        Set<Id> ccrContactIds  = new Set<Id>();
        Set<Id> aarAccountIds  = new Set<Id>();

        for (FARContext ctx : contexts) {
            if (ctx.poType == TYPE_BUSINESS && ctx.raType == TYPE_INDIVIDUAL) {
                acrAccountIds.add(ctx.poId);
                if (ctx.raPersonContactId != null) acrContactIds.add(ctx.raPersonContactId);
            } else if (ctx.poType == TYPE_INDIVIDUAL && ctx.raType == TYPE_INDIVIDUAL) {
                if (ctx.poPersonContactId != null) ccrContactIds.add(ctx.poPersonContactId);
                if (ctx.raPersonContactId != null) ccrContactIds.add(ctx.raPersonContactId);
            } else if (ctx.poType == TYPE_INDIVIDUAL && ctx.raType == TYPE_BUSINESS) {
                acrAccountIds.add(ctx.raId);
                if (ctx.poPersonContactId != null) acrContactIds.add(ctx.poPersonContactId);
            } else if (ctx.poType == TYPE_BUSINESS && ctx.raType == TYPE_BUSINESS) {
                aarAccountIds.add(ctx.poId);
                aarAccountIds.add(ctx.raId);
            }
        }

        Map<String, AccountContactRelation> existingACRs = queryExistingACRs(acrAccountIds, acrContactIds);
        Map<String, FinServ__ContactContactRelation__c> existingCCRs = queryExistingCCRs(ccrContactIds, authSignerContRoleId);
        Map<String, FinServ__AccountAccountRelation__c> existingAARs = queryExistingAARs(aarAccountIds, authSignerAcctRoleId);

        List<AccountContactRelation> acrToCreate  = new List<AccountContactRelation>();
        List<AccountContactRelation> acrToUpdate  = new List<AccountContactRelation>();
        List<FinServ__ContactContactRelation__c> ccrToCreate  = new List<FinServ__ContactContactRelation__c>();
        List<FinServ__AccountAccountRelation__c> aarToCreate  = new List<FinServ__AccountAccountRelation__c>();
        List<String> errors = new List<String>();

        // Track which FARs correspond to which ACR so we can retry on row lock
        Map<Integer, FinServ__FinancialAccountRole__c> acrIndexToFAR = new Map<Integer, FinServ__FinancialAccountRole__c>();

        for (FARContext ctx : contexts) {
            if (ctx.poType == TYPE_BUSINESS && ctx.raType == TYPE_INDIVIDUAL) {
                if (ctx.raPersonContactId == null) {
                    errors.add('RelatedAccount ' + ctx.raId + ' has no PersonContactId. FAR: ' + ctx.farId);
                    continue;
                }
                String key = ctx.poId + '_' + ctx.raPersonContactId;
                AccountContactRelation existing = existingACRs.get(key);
                if (existing != null) {
                    if (!roleContains(existing.Roles, ROLE_LABEL)) {
                        existing.Roles = appendRole(existing.Roles, ROLE_LABEL);
                        acrToUpdate.add(existing);
                    }
                } else {
                    acrIndexToFAR.put(acrToCreate.size(), ctx.sourceFAR);
                    acrToCreate.add(buildACR(ctx.poId, ctx.raPersonContactId));
                }
            } else if (ctx.poType == TYPE_INDIVIDUAL && ctx.raType == TYPE_INDIVIDUAL) {
                if (ctx.poPersonContactId == null || ctx.raPersonContactId == null) {
                    errors.add('Missing PersonContactId on PO or RA. FAR: ' + ctx.farId);
                    continue;
                }
                if (authSignerContRoleId == null) {
                    errors.add('ReciprocalRole "' + ROLE_LABEL + '" not found in org. FAR: ' + ctx.farId);
                    continue;
                }
                String key = ctx.raPersonContactId + '_' + ctx.poPersonContactId;
                if (!existingCCRs.containsKey(key)) {
                    ccrToCreate.add(buildCCR(ctx.raPersonContactId, ctx.poPersonContactId, authSignerContRoleId));
                }
            } else if (ctx.poType == TYPE_INDIVIDUAL && ctx.raType == TYPE_BUSINESS) {
                if (ctx.poPersonContactId == null) {
                    errors.add('PrimaryOwner ' + ctx.poId + ' has no PersonContactId. FAR: ' + ctx.farId);
                    continue;
                }
                String key = ctx.raId + '_' + ctx.poPersonContactId;
                AccountContactRelation existing = existingACRs.get(key);
                if (existing != null) {
                    if (!roleContains(existing.Roles, ROLE_LABEL)) {
                        existing.Roles = appendRole(existing.Roles, ROLE_LABEL);
                        acrToUpdate.add(existing);
                    }
                } else {
                    acrIndexToFAR.put(acrToCreate.size(), ctx.sourceFAR);
                    acrToCreate.add(buildACR(ctx.raId, ctx.poPersonContactId));
                }
            } else if (ctx.poType == TYPE_BUSINESS && ctx.raType == TYPE_BUSINESS) {
                if (authSignerAcctRoleId == null) {
                    errors.add('ReciprocalRole "' + ROLE_LABEL + '" not found in org. FAR: ' + ctx.farId);
                    continue;
                }
                String key = ctx.poId + '_' + ctx.raId;
                if (!existingAARs.containsKey(key)) {
                    aarToCreate.add(buildAAR(ctx.poId, ctx.raId, authSignerAcctRoleId));
                }
            }
        }

        List<FinServ__FinancialAccountRole__c> retryFARs = new List<FinServ__FinancialAccountRole__c>();
        if (!acrToCreate.isEmpty()) {
            Database.SaveResult[] acrResults = Database.insert(acrToCreate, false);
            for (Integer i = 0; i < acrResults.size(); i++) {
                if (!acrResults[i].isSuccess()) {
                    for (Database.Error err : acrResults[i].getErrors()) {
                        if (err.getStatusCode() == StatusCode.UNABLE_TO_LOCK_ROW) {
                            if (retryCount < MAX_RETRIES && acrIndexToFAR.containsKey(i)) {
                                retryFARs.add(acrIndexToFAR.get(i));
                            } else if (retryCount >= MAX_RETRIES) {
                                errors.add('[ACR Insert] Max retries reached. UNABLE_TO_LOCK_ROW on FAR: '
                                    + (acrIndexToFAR.containsKey(i) ? acrIndexToFAR.get(i).Id : 'unknown'));
                            }
                        } else if (err.getStatusCode() == StatusCode.DUPLICATE_VALUE) {
                            // ACR already exists so do nothing
                        } else {
                            errors.add('[ACR Insert] ' + err.getStatusCode() + ': ' + err.getMessage());
                        }
                    }
                }
            }
        }

        if (!acrToUpdate.isEmpty())  collectErrors(Database.update(acrToUpdate, false), 'ACR Update', errors);
        if (!ccrToCreate.isEmpty())  collectErrors(Database.insert(ccrToCreate, false), 'CCR Insert', errors);
        if (!aarToCreate.isEmpty())  collectErrors(Database.insert(aarToCreate, false), 'AAR Insert', errors);

        if (!retryFARs.isEmpty()) {
            System.enqueueJob(new FinancialAccountRoleQueueable(retryFARs, null, retryCount + 1));
        }

        if (!errors.isEmpty()) sendErrorEmail(String.join(errors, '\n'));
    }

    private void processDeletes(List<FinServ__FinancialAccountRole__c> farList) {
        Set<Id> faIds = new Set<Id>();
        Set<Id> raIds = new Set<Id>();

        for (FinServ__FinancialAccountRole__c far : farList) {
            faIds.add(far.FinServ__FinancialAccount__c);
            raIds.add(far.FinServ__RelatedAccount__c);
        }

        Map<Id, FinServ__FinancialAccount__c> faMap = new Map<Id, FinServ__FinancialAccount__c>([
            SELECT Id,
                FinServ__PrimaryOwner__c,
                FinServ__PrimaryOwner__r.BKU_Record_Type_Name__c,
                FinServ__PrimaryOwner__r.PersonContactId
            FROM FinServ__FinancialAccount__c
            WHERE Id IN :faIds
        ]);

        Map<Id, Account> raMap = new Map<Id, Account>([
            SELECT Id, BKU_Record_Type_Name__c, PersonContactId
            FROM Account
            WHERE Id IN :raIds
        ]);

        Map<String, Id> reciprocalRoleMapAcct = getReciprocalRoleIdMap('AccountRole');
        Id authSignerAcctRoleId = reciprocalRoleMapAcct.get(ROLE_LABEL);
        Map<String, Id> reciprocalRoleMapCont = getReciprocalRoleIdMap('ContactRole');
        Id authSignerContRoleId = reciprocalRoleMapCont.get(ROLE_LABEL);

        List<FARContext> allDeleteContexts = new List<FARContext>();
        for (FinServ__FinancialAccountRole__c far : farList) {
            FinServ__FinancialAccount__c fa = faMap.get(far.FinServ__FinancialAccount__c);
            Account ra = raMap.get(far.FinServ__RelatedAccount__c);
            if (fa == null || ra == null) continue;

            allDeleteContexts.add(new FARContext(
                far.Id,
                fa.FinServ__PrimaryOwner__r.BKU_Record_Type_Name__c,
                ra.BKU_Record_Type_Name__c,
                fa.FinServ__PrimaryOwner__c,
                far.FinServ__RelatedAccount__c,
                fa.FinServ__PrimaryOwner__r.PersonContactId,
                ra.PersonContactId,
                far
            ));
        }

        if (allDeleteContexts.isEmpty()) return;

        Set<Id> poIds = new Set<Id>();
        for (FARContext ctx : allDeleteContexts) poIds.add(ctx.poId);

        Map<Id, Set<Id>> poToFAIds = new Map<Id, Set<Id>>();
        for (FinServ__FinancialAccount__c fa : [
            SELECT Id, FinServ__PrimaryOwner__c
            FROM FinServ__FinancialAccount__c
            WHERE FinServ__PrimaryOwner__c IN :poIds
        ]) {
            if (!poToFAIds.containsKey(fa.FinServ__PrimaryOwner__c)) {
                poToFAIds.put(fa.FinServ__PrimaryOwner__c, new Set<Id>());
            }
            poToFAIds.get(fa.FinServ__PrimaryOwner__c).add(fa.Id);
        }

        Set<Id> allFAIds = new Set<Id>();
        for (Set<Id> s : poToFAIds.values()) allFAIds.addAll(s);

        Map<String, Integer> remainingCountByPORA = new Map<String, Integer>();
        for (FinServ__FinancialAccountRole__c remaining : [
            SELECT Id,
                FinServ__RelatedAccount__c,
                FinServ__FinancialAccount__r.FinServ__PrimaryOwner__c
            FROM FinServ__FinancialAccountRole__c
            WHERE FinServ__FinancialAccount__c IN :allFAIds
            AND   FinServ__RelatedAccount__c   IN :raIds
            AND   FinServ__Role__c             = :AUTHORIZED_SIGNER_ROLE
        ]) {
            String key = remaining.FinServ__FinancialAccount__r.FinServ__PrimaryOwner__c
                    + '_' + remaining.FinServ__RelatedAccount__c;
            remainingCountByPORA.put(key, (remainingCountByPORA.get(key) ?? 0) + 1);
        }

        List<FARContext> toRemove = new List<FARContext>();
        for (FARContext ctx : allDeleteContexts) {
            if (!remainingCountByPORA.containsKey(ctx.poId + '_' + ctx.raId)) {
                toRemove.add(ctx);
            }
        }

        if (toRemove.isEmpty()) return;

        Set<Id> acrAccountIds = new Set<Id>();
        Set<Id> acrContactIds = new Set<Id>();
        Set<Id> ccrContactIds = new Set<Id>();
        Set<Id> aarAccountIds = new Set<Id>();

        for (FARContext ctx : toRemove) {
            if (ctx.poType == TYPE_BUSINESS && ctx.raType == TYPE_INDIVIDUAL) {
                acrAccountIds.add(ctx.poId);
                if (ctx.raPersonContactId != null) acrContactIds.add(ctx.raPersonContactId);
            } else if (ctx.poType == TYPE_INDIVIDUAL && ctx.raType == TYPE_INDIVIDUAL) {
                if (ctx.poPersonContactId != null) ccrContactIds.add(ctx.poPersonContactId);
                if (ctx.raPersonContactId != null) ccrContactIds.add(ctx.raPersonContactId);
            } else if (ctx.poType == TYPE_INDIVIDUAL && ctx.raType == TYPE_BUSINESS) {
                acrAccountIds.add(ctx.raId);
                if (ctx.poPersonContactId != null) acrContactIds.add(ctx.poPersonContactId);
            } else if (ctx.poType == TYPE_BUSINESS && ctx.raType == TYPE_BUSINESS) {
                aarAccountIds.add(ctx.poId);
                aarAccountIds.add(ctx.raId);
            }
        }

        Map<String, AccountContactRelation>             existingACRs = queryExistingACRs(acrAccountIds, acrContactIds);
        Map<String, FinServ__ContactContactRelation__c> existingCCRs = queryExistingCCRs(ccrContactIds, authSignerContRoleId);
        Map<String, FinServ__AccountAccountRelation__c> existingAARs = queryExistingAARs(aarAccountIds, authSignerAcctRoleId);

        Map<Id, AccountContactRelation>             acrToUpdateMap = new Map<Id, AccountContactRelation>();
        Map<Id, AccountContactRelation>             acrToDeleteMap = new Map<Id, AccountContactRelation>();
        Map<Id, FinServ__ContactContactRelation__c> ccrToDeleteMap = new Map<Id, FinServ__ContactContactRelation__c>();
        Map<Id, FinServ__AccountAccountRelation__c> aarToDeleteMap = new Map<Id, FinServ__AccountAccountRelation__c>();
        List<String> errors = new List<String>();

        for (FARContext ctx : toRemove) {
            if (ctx.poType == TYPE_BUSINESS && ctx.raType == TYPE_INDIVIDUAL) {
                if (ctx.raPersonContactId == null) continue;
                AccountContactRelation acr = existingACRs.get(ctx.poId + '_' + ctx.raPersonContactId);
                if (acr != null) {
                    String updatedRoles = removeRole(acr.Roles, ROLE_LABEL);
                    if (String.isBlank(updatedRoles)) {
                        acrToDeleteMap.put(acr.Id, acr);
                    } else {
                        acr.Roles = updatedRoles;
                        acrToUpdateMap.put(acr.Id, acr);
                    }
                }
            } else if (ctx.poType == TYPE_INDIVIDUAL && ctx.raType == TYPE_INDIVIDUAL) {
                if (ctx.raPersonContactId == null || ctx.poPersonContactId == null) continue;
                FinServ__ContactContactRelation__c ccr = existingCCRs.get(
                    ctx.raPersonContactId + '_' + ctx.poPersonContactId
                );
                if (ccr != null) ccrToDeleteMap.put(ccr.Id, ccr);
            } else if (ctx.poType == TYPE_INDIVIDUAL && ctx.raType == TYPE_BUSINESS) {
                if (ctx.poPersonContactId == null) continue;
                AccountContactRelation acr = existingACRs.get(ctx.raId + '_' + ctx.poPersonContactId);
                if (acr != null) {
                    String updatedRoles = removeRole(acr.Roles, ROLE_LABEL);
                    if (String.isBlank(updatedRoles)) {
                        acrToDeleteMap.put(acr.Id, acr);
                    } else {
                        acr.Roles = updatedRoles;
                        acrToUpdateMap.put(acr.Id, acr);
                    }
                }
            } else if (ctx.poType == TYPE_BUSINESS && ctx.raType == TYPE_BUSINESS) {
                FinServ__AccountAccountRelation__c aar = existingAARs.get(ctx.poId + '_' + ctx.raId);
                if (aar != null) aarToDeleteMap.put(aar.Id, aar);
            }
        }

        AccountContactRelationTriggerHandler.suppressTrigger = true;
        try {
            if (!acrToUpdateMap.isEmpty()) collectErrors(Database.update(acrToUpdateMap.values(), false), 'ACR Role Remove', errors);
            if (!acrToDeleteMap.isEmpty()) collectDeleteErrors(Database.delete(acrToDeleteMap.values(), false), 'ACR Delete', errors);
        } finally {
            AccountContactRelationTriggerHandler.suppressTrigger = false;
        }

        if (!ccrToDeleteMap.isEmpty()) collectDeleteErrors(Database.delete(ccrToDeleteMap.values(), false), 'CCR Delete', errors);
        if (!aarToDeleteMap.isEmpty()) collectDeleteErrors(Database.delete(aarToDeleteMap.values(), false), 'AAR Delete', errors);

        if (!errors.isEmpty()) sendErrorEmail(String.join(errors, '\n'));
    }

    private Map<String, AccountContactRelation> queryExistingACRs(Set<Id> accountIds, Set<Id> contactIds) {
        Map<String, AccountContactRelation> result = new Map<String, AccountContactRelation>();
        if (accountIds.isEmpty() || contactIds.isEmpty()) return result;
        for (AccountContactRelation acr : [
            SELECT Id, AccountId, ContactId, Roles
            FROM AccountContactRelation
            WHERE AccountId IN :accountIds
            AND   ContactId IN :contactIds
        ]) {
            result.put(acr.AccountId + '_' + acr.ContactId, acr);
        }
        return result;
    }

    private Map<String, FinServ__ContactContactRelation__c> queryExistingCCRs(
        Set<Id> contactIds,
        Id authSignerRoleId
    ) {
        Map<String, FinServ__ContactContactRelation__c> result = new Map<String, FinServ__ContactContactRelation__c>();
        if (contactIds.isEmpty() || authSignerRoleId == null) return result;
        for (FinServ__ContactContactRelation__c ccr : [
            SELECT Id, FinServ__Contact__c, FinServ__RelatedContact__c
            FROM FinServ__ContactContactRelation__c
            WHERE FinServ__Contact__c       IN :contactIds
            AND   FinServ__RelatedContact__c IN :contactIds
            AND   FinServ__Role__c           = :authSignerRoleId
        ]) {
            result.put(ccr.FinServ__Contact__c + '_' + ccr.FinServ__RelatedContact__c, ccr);
        }
        return result;
    }

    private Map<String, FinServ__AccountAccountRelation__c> queryExistingAARs(
        Set<Id> accountIds,
        Id authSignerRoleId
    ) {
        Map<String, FinServ__AccountAccountRelation__c> result = new Map<String, FinServ__AccountAccountRelation__c>();
        if (accountIds.isEmpty() || authSignerRoleId == null) return result;
        for (FinServ__AccountAccountRelation__c aar : [
            SELECT Id, FinServ__Account__c, FinServ__RelatedAccount__c
            FROM FinServ__AccountAccountRelation__c
            WHERE FinServ__Account__c        IN :accountIds
            AND   FinServ__RelatedAccount__c IN :accountIds
            AND   FinServ__Role__c           = :authSignerRoleId
        ]) {
            result.put(aar.FinServ__Account__c + '_' + aar.FinServ__RelatedAccount__c, aar);
        }
        return result;
    }

    private Map<String, Id> getReciprocalRoleIdMap(String rtName) {
        Map<String, Id> roleMap = new Map<String, Id>();
        for (FinServ__ReciprocalRole__c rr : [
            SELECT Id, Name
            FROM FinServ__ReciprocalRole__c
            WHERE RecordType.DeveloperName = :rtName
        ]) {
            roleMap.put(rr.Name, rr.Id);
        }
        return roleMap;
    }

    private AccountContactRelation buildACR(Id accountId, Id contactId) {
        AccountContactRelation acr = new AccountContactRelation();
        acr.AccountId = accountId;
        acr.ContactId = contactId;
        acr.Roles     = ROLE_LABEL;
        acr.IsActive  = true;
        return acr;
    }

    private FinServ__ContactContactRelation__c buildCCR(Id contactId, Id relatedContactId, Id roleId) {
        FinServ__ContactContactRelation__c ccr = new FinServ__ContactContactRelation__c();
        ccr.FinServ__Contact__c        = contactId;  
        ccr.FinServ__RelatedContact__c = relatedContactId; 
        ccr.FinServ__Role__c           = roleId;
        ccr.FinServ__Active__c       = true;
        return ccr;
    }

    private FinServ__AccountAccountRelation__c buildAAR(Id accountId, Id relatedAccountId, Id roleId) {
        FinServ__AccountAccountRelation__c aar = new FinServ__AccountAccountRelation__c();
        aar.FinServ__Account__c         = accountId;
        aar.FinServ__RelatedAccount__c  = relatedAccountId;
        aar.FinServ__Role__c            = roleId;
        aar.FinServ__AssociationType__c = ASSOC_TYPE_PEER;
        aar.FinServ__Active__c        = true;
        return aar;
    }

    private List<FARContext> buildContexts(List<FinServ__FinancialAccountRole__c> enriched) {
        List<FARContext> contexts = new List<FARContext>();
        for (FinServ__FinancialAccountRole__c far : enriched) {
            contexts.add(new FARContext(
                far.Id,
                far.FinServ__FinancialAccount__r.FinServ__PrimaryOwner__r.BKU_Record_Type_Name__c,
                far.FinServ__RelatedAccount__r.BKU_Record_Type_Name__c,
                far.FinServ__FinancialAccount__r.FinServ__PrimaryOwner__c,
                far.FinServ__RelatedAccount__c,
                far.FinServ__FinancialAccount__r.FinServ__PrimaryOwner__r.PersonContactId,
                far.FinServ__RelatedAccount__r.PersonContactId,
                far
            ));
        }
        return contexts;
    }

    private Boolean roleContains(String roles, String roleToCheck) {
        if (String.isBlank(roles)) return false;
        for (String r : roles.split(';')) {
            if (r.trim() == roleToCheck) return true;
        }
        return false;
    }

    private String appendRole(String existingRoles, String newRole) {
        return String.isBlank(existingRoles) ? newRole : existingRoles + ';' + newRole;
    }

    private String removeRole(String existingRoles, String roleToRemove) {
        if (String.isBlank(existingRoles)) return '';
        List<String> kept = new List<String>();
        for (String r : existingRoles.split(';')) {
            if (r.trim() != roleToRemove) kept.add(r.trim());
        }
        return String.join(kept, ';');
    }

    private void collectErrors(Database.SaveResult[] results, String context, List<String> errors) {
        for (Database.SaveResult sr : results) {
            if (!sr.isSuccess()) {
                for (Database.Error err : sr.getErrors()) {
                    errors.add('[' + context + '] ' + err.getStatusCode() + ': ' + err.getMessage());
                }
            }
        }
    }

    private void collectDeleteErrors(Database.DeleteResult[] results, String context, List<String> errors) {
        for (Database.DeleteResult dr : results) {
            if (!dr.isSuccess()) {
                for (Database.Error err : dr.getErrors()) {
                    errors.add('[' + context + '] ' + err.getStatusCode() + ': ' + err.getMessage());
                }
            }
        }
    }

    private void sendErrorEmail(String errorBody) {
        try {
            List<OrgWideEmailAddress> owas = [
                SELECT Id FROM OrgWideEmailAddress WHERE Address = :HELPDESK_EMAIL LIMIT 1
            ];
            Messaging.SingleEmailMessage email = new Messaging.SingleEmailMessage();
            email.setToAddresses(new List<String>{ HELPDESK_EMAIL });
            if (!owas.isEmpty()) {
                email.setOrgWideEmailAddressId(owas[0].Id);
            }
            email.setSubject('ERROR: Financial Account Role – Authorized Signer Processing Failed');
            email.setPlainTextBody(
                'One or more errors occurred while processing Financial Account Role records '
                + '(Authorized Signer sync).\n\nDetails:\n' + errorBody
            );
            Messaging.sendEmail(new List<Messaging.SingleEmailMessage>{ email });
        } catch (Exception e) {
            System.debug(LoggingLevel.ERROR, 'sendErrorEmail failed: ' + e.getMessage());
        }
    }

    private class FARContext {
        public Id     farId;
        public String poType;
        public String raType;
        public Id     poId;
        public Id     raId;
        public Id     poPersonContactId;
        public Id     raPersonContactId;
        public FinServ__FinancialAccountRole__c sourceFAR;

        public FARContext(
            Id farId, String poType, String raType,
            Id poId,  Id raId,
            Id poPersonContactId, Id raPersonContactId,
            FinServ__FinancialAccountRole__c sourceFAR
        ) {
            this.farId              = farId;
            this.poType             = poType;
            this.raType             = raType;
            this.poId               = poId;
            this.raId               = raId;
            this.poPersonContactId  = poPersonContactId;
            this.raPersonContactId  = raPersonContactId;
            this.sourceFAR         = sourceFAR;
        }
    }
}
