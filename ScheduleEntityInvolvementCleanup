public with sharing class ScheduleEntityInvolvementCleanup implements Schedulable {
 
    // Keep batch size modest (200 is the ceiling and the safest default
    // for DML-heavy batches with related lookups)
    private static final Integer BATCH_SIZE = 200;
 
    public void execute(SchedulableContext sc) {
        Database.executeBatch(new BatchEntityInvolvementCleanup(), BATCH_SIZE);
    }
}
