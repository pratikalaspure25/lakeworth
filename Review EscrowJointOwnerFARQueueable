    private Map<String, Id> getReciprocalRoleIdMap(String rtName) {
        Map<String, Id> roleMap = new Map<String, Id>();
        for (FinServ__ReciprocalRole__c rr : [
            SELECT Id, Name
            FROM FinServ__ReciprocalRole__c
            WHERE RecordType.DeveloperName = :rtName
              AND Name IN :QUALIFYING_ROLES
        ]) {
            roleMap.put(rr.Name, rr.Id);
        }
        return roleMap;
    }

    // =========================================================
    // BUILDERS
    // =========================================================
    private List<FARContext> buildContexts(
        List<FinServ__FinancialAccountRole__c> enriched
    ) {
        List<FARContext> contexts = new List<FARContext>();
        for (FinServ__FinancialAccountRole__c far : enriched) {
            contexts.add(new FARContext(
                far.Id,
                far.FinServ__Role__c,
                far.FinServ__FinancialAccount__r
                    .FinServ__PrimaryOwner__r.BKU_Record_Type_Name__c,
                far.FinServ__RelatedAccount__r.BKU_Record_Type_Name__c,
                far.FinServ__FinancialAccount__r.FinServ__PrimaryOwner__c,
                far.FinServ__RelatedAccount__c,
                far.FinServ__FinancialAccount__r
                    .FinServ__PrimaryOwner__r.PersonContactId,
                far.FinServ__RelatedAccount__r.PersonContactId,
                far
            ));
        }
        return contexts;
    }

    private AccountContactRelation buildACR(
        Id accountId, Id contactId, String roleLabel
    ) {
        AccountContactRelation acr = new AccountContactRelation();
        acr.AccountId = accountId;
        acr.ContactId = contactId;
        acr.Roles     = roleLabel;
        acr.IsActive  = true;
        return acr;
    }

    private FinServ__ContactContactRelation__c buildCCR(
        Id contactId, Id relatedContactId, Id roleId
    ) {
        FinServ__ContactContactRelation__c ccr =
            new FinServ__ContactContactRelation__c();
        ccr.FinServ__Contact__c        = contactId;
        ccr.FinServ__RelatedContact__c = relatedContactId;
        ccr.FinServ__Role__c           = roleId;
        ccr.FinServ__Active__c         = true;
        return ccr;
    }

    private FinServ__AccountAccountRelation__c buildAAR(
        Id accountId, Id relatedAccountId, Id roleId
    ) {
        FinServ__AccountAccountRelation__c aar =
            new FinServ__AccountAccountRelation__c();
        aar.FinServ__Account__c         = accountId;
        aar.FinServ__RelatedAccount__c  = relatedAccountId;
        aar.FinServ__Role__c            = roleId;
        aar.FinServ__AssociationType__c = ASSOC_TYPE_PEER;
        aar.FinServ__Active__c          = true;
        return aar;
    }

    // =========================================================
    // ROLE UTILITIES
    // =========================================================
    private Boolean roleContains(String roles, String roleToCheck) {
        if (String.isBlank(roles)) return false;
        for (String r : roles.split(';')) {
            if (r.trim() == roleToCheck) return true;
        }
        return false;
    }

    private String appendRole(String existingRoles, String newRole) {
        return String.isBlank(existingRoles)
            ? newRole
            : existingRoles + ';' + newRole;
    }

    private String removeRole(String existingRoles, String roleToRemove) {
        if (String.isBlank(existingRoles)) return '';
        List<String> kept = new List<String>();
        for (String r : existingRoles.split(';')) {
            if (r.trim() != roleToRemove) kept.add(r.trim());
        }
        return String.join(kept, ';');
    }

    // =========================================================
    // ERROR HANDLING
    // =========================================================
    private void collectErrors(
        Database.SaveResult[] results,
        String ctx,
        List<String> errors
    ) {
        for (Database.SaveResult sr : results) {
            
            System.debug('CTX=' + ctx);
            System.debug('SUCCESS=' + sr.isSuccess());
            
            if (sr.isSuccess()) {
                System.debug('UPDATED ID=' + sr.getId());
            } else {
                for (Database.Error err : sr.getErrors()) {
                    
                    System.debug(
                        'ERROR=' +
                        err.getStatusCode() +
                        ' : ' +
                        err.getMessage()
                    );
                    
                    errors.add(
                        '[' + ctx + '] '
                        + err.getStatusCode()
                        + ': '
                        + err.getMessage()
                    );
                }
            }
        }
    }

    private void collectDeleteErrors(
        Database.DeleteResult[] results,
        String ctx,
        List<String> errors
    ) {
        for (Database.DeleteResult dr : results) {
            if (!dr.isSuccess()) {
                for (Database.Error err : dr.getErrors()) {
                    errors.add('[' + ctx + '] '
                        + err.getStatusCode()
                        + ': ' + err.getMessage());
                }
            }
        }
    }

    private void sendErrorEmail(String errorBody) {
        try {
            List<OrgWideEmailAddress> owas = [
                SELECT Id FROM OrgWideEmailAddress
                WHERE Address = :HELPDESK_EMAIL LIMIT 1
            ];
            Messaging.SingleEmailMessage email =
                new Messaging.SingleEmailMessage();
            email.setToAddresses(new List<String>{ HELPDESK_EMAIL });
            if (!owas.isEmpty()) {
                email.setOrgWideEmailAddressId(owas[0].Id);
            }
            email.setSubject(
                'ERROR: Financial Account Role '
                + '– Escrow Agent / Joint Owner Sync Failed'
            );
            email.setPlainTextBody(
                'One or more errors occurred while processing '
                + 'Financial Account Role records '
                + '(Escrow Agent / Joint Owner sync).'
                + '\n\nDetails:\n' + errorBody
            );
            Messaging.sendEmail(
                new List<Messaging.SingleEmailMessage>{ email }
            );
        } catch (Exception e) {
            System.debug(
                LoggingLevel.ERROR,
                'sendErrorEmail failed: ' + e.getMessage()
            );
        }
    }

