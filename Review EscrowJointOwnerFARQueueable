public without sharing class EscrowJointOwnerFARQueueable implements Queueable {

    // ── Constants ────────────────────────────────────────────────────
    private static final Set<String> QUALIFYING_ROLES = new Set<String>{
        'Escrow Agent',
        'Joint Owner'
    };
    private static final Set<String> QUALIFYING_SPECIAL_CASES = new Set<String>{
        'FIDUCIARY',
        'IOLA/IOLTA'
    };
    private static final String DEPOSIT_RT_DEV_NAME = 'BankingAccount';
    private static final String TYPE_INDIVIDUAL     = 'Individual';
    private static final String TYPE_BUSINESS       = 'Business';
    private static final String ASSOC_TYPE_PEER     = 'Peer';
    private static final String HELPDESK_EMAIL      = 'crm360helpdesk@bankunited.com';
    private static final Integer MAX_RETRIES        = 3;

    // ── Instance Variables ───────────────────────────────────────────
    private List<FinServ__FinancialAccountRole__c> insertedFARs;
    private List<FinServ__FinancialAccountRole__c> deletedFARs;
    private Integer retryCount;

    // ── Constructors ─────────────────────────────────────────────────
    public EscrowJointOwnerFARQueueable(
        List<FinServ__FinancialAccountRole__c> insertedFARs,
        List<FinServ__FinancialAccountRole__c> deletedFARs
    ) {
        this(insertedFARs, deletedFARs, 0);
    }

    public EscrowJointOwnerFARQueueable(
        List<FinServ__FinancialAccountRole__c> insertedFARs,
        List<FinServ__FinancialAccountRole__c> deletedFARs,
        Integer retryCount
    ) {
        this.insertedFARs = insertedFARs;
        this.deletedFARs  = deletedFARs;
        this.retryCount   = retryCount;
    }

    // ── Execute ──────────────────────────────────────────────────────
    public void execute(QueueableContext context) {
        try {
            if (insertedFARs != null && !insertedFARs.isEmpty()) {
                processInserts(insertedFARs);
            }
            if (deletedFARs != null && !deletedFARs.isEmpty()) {
                processDeletes(deletedFARs);
            }
        } catch (Exception e) {
            sendErrorEmail(
                'Unhandled exception:\n'
                + e.getMessage() + '\n'
                + e.getStackTraceString()
            );
        }
    }

