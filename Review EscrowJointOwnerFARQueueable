        if (!acrToCreate.isEmpty()) {
            Database.SaveResult[] results =
                Database.insert(acrToCreate, false);
            for (Integer i = 0; i < results.size(); i++) {
                if (!results[i].isSuccess()) {
                    for (Database.Error err : results[i].getErrors()) {
                        if (err.getStatusCode()
                                == StatusCode.UNABLE_TO_LOCK_ROW) {
                            if (retryCount < MAX_RETRIES
                                    && acrIndexToFAR.containsKey(i)) {
                                retryFARs.add(acrIndexToFAR.get(i));
                            } else {
                                errors.add('[ACR Insert] Max retries. FAR: '
                                    + (acrIndexToFAR.containsKey(i)
                                        ? acrIndexToFAR.get(i).Id
                                        : 'unknown'));
                            }
                        } else if (err.getStatusCode()
                                != StatusCode.DUPLICATE_VALUE) {
                            errors.add('[ACR Insert] '
                                + err.getStatusCode()
                                + ': ' + err.getMessage());
                        }
                    }
                }
            }
        }

        System.debug('acrToUpdate Size = ' + acrToUpdate.size());
		System.debug('acrToUpdate = ' + acrToUpdate);
        if (!acrToUpdate.isEmpty()) {
            collectErrors(
