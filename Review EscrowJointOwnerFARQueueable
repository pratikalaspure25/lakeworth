        System.debug('CCR TO CREATE = ' + ccrToCreate);

        if (!ccrToCreate.isEmpty()) {
            
            Database.SaveResult[] ccrResults =
                Database.insert(ccrToCreate, false);
            
            collectErrors(
                ccrResults,
                'CCR Insert',
                errors
            );
        }
        /*if (!aarToCreate.isEmpty()) {
            collectErrors(
                Database.insert(aarToCreate, false),
                'AAR Insert', errors
            );
        }*/

        System.debug('AAR TO CREATE SIZE = ' + aarToCreate.size());
        System.debug('AAR TO CREATE = ' + aarToCreate);
        
        if (!aarToCreate.isEmpty()) {
            
            Database.SaveResult[] results =
                Database.insert(aarToCreate, false);
            
            collectErrors(
                results,
                'AAR Insert',
                errors
            );
        }

        if (!retryFARs.isEmpty()) {
            System.enqueueJob(new EscrowJointOwnerFARQueueable(
                retryFARs, null, retryCount + 1
            ));
        }
        if (!errors.isEmpty()) {
            sendErrorEmail(String.join(errors, '\n'));
        }
    }

    // =========================================================
    // PROCESS DELETES — AC9, AC10
    // =========================================================
    private void processDeletes(
        List<FinServ__FinancialAccountRole__c> farList
    ) {
        Set<Id> faIds = new Set<Id>();
        Set<Id> raIds = new Set<Id>();
        for (FinServ__FinancialAccountRole__c far : farList) {
            faIds.add(far.FinServ__FinancialAccount__c);
            raIds.add(far.FinServ__RelatedAccount__c);
        }

        // Fetch FA details
        Map<Id, FinServ__FinancialAccount__c> faMap =
            new Map<Id, FinServ__FinancialAccount__c>([
                SELECT Id,
                       RecordType.DeveloperName,
                       BKU_Special_Case__c,
                       FinServ__PrimaryOwner__c,
                       FinServ__PrimaryOwner__r.BKU_Record_Type_Name__c,
                       FinServ__PrimaryOwner__r.PersonContactId
                FROM FinServ__FinancialAccount__c
                WHERE Id IN :faIds
            ]);

        // Fetch RA details
        Map<Id, Account> raMap = new Map<Id, Account>([
            SELECT Id, BKU_Record_Type_Name__c, PersonContactId
            FROM Account
            WHERE Id IN :raIds
        ]);

        Map<String, Id> acctRoleMap = getReciprocalRoleIdMap('AccountRole');
        Map<String, Id> contRoleMap = getReciprocalRoleIdMap('ContactRole');

        // Build delete contexts — only qualified FARs
        List<FARContext> allContexts = new List<FARContext>();
        for (FinServ__FinancialAccountRole__c far : farList) {
            FinServ__FinancialAccount__c fa =
                faMap.get(far.FinServ__FinancialAccount__c);
            Account ra = raMap.get(far.FinServ__RelatedAccount__c);
            if (fa == null || ra == null) continue;
            if (!isQualifiedFA(fa)) continue;

            allContexts.add(new FARContext(
                far.Id,
                far.FinServ__Role__c,
                fa.FinServ__PrimaryOwner__r.BKU_Record_Type_Name__c,
                ra.BKU_Record_Type_Name__c,
                fa.FinServ__PrimaryOwner__c,
                far.FinServ__RelatedAccount__c,
                fa.FinServ__PrimaryOwner__r.PersonContactId,
                ra.PersonContactId,
                far
            ));
        }
        if (allContexts.isEmpty()) return;

        // Guard: only remove if no other qualifying FAR
        // still links same PO + RA + Role
        Set<Id> poIds = new Set<Id>();
        for (FARContext ctx : allContexts) poIds.add(ctx.poId);

        Set<Id> qualifiedFAIds = new Set<Id>();
        for (FinServ__FinancialAccount__c fa : [
            SELECT Id
            FROM FinServ__FinancialAccount__c
            WHERE FinServ__PrimaryOwner__c IN :poIds
              AND RecordType.DeveloperName  = :DEPOSIT_RT_DEV_NAME
              AND BKU_Special_Case__c       IN :QUALIFYING_SPECIAL_CASES
        ]) {
            qualifiedFAIds.add(fa.Id);
        }

        Map<String, Integer> remainingCount =
            new Map<String, Integer>();
        for (FinServ__FinancialAccountRole__c remaining : [
            SELECT Id,
                   FinServ__Role__c,
                   FinServ__RelatedAccount__c,
                   FinServ__FinancialAccount__r.FinServ__PrimaryOwner__c
            FROM FinServ__FinancialAccountRole__c
            WHERE FinServ__FinancialAccount__c IN :qualifiedFAIds
              AND FinServ__RelatedAccount__c   IN :raIds
              AND FinServ__Role__c             IN :QUALIFYING_ROLES
        ]) {
            String key =
                remaining.FinServ__FinancialAccount__r
                    .FinServ__PrimaryOwner__c
                + '_' + remaining.FinServ__RelatedAccount__c
                + '_' + remaining.FinServ__Role__c;
            remainingCount.put(
                key, (remainingCount.get(key) ?? 0) + 1
            );
        }

        // Only remove relationships with zero remaining FARs
        /*List<FARContext> toRemove = new List<FARContext>();
        for (FARContext ctx : allContexts) {
            String key = ctx.poId + '_' + ctx.raId + '_' + ctx.role;
            if (!remainingCount.containsKey(key)) {
                toRemove.add(ctx);
            }
        }*/

        List<FARContext> toRemove = new List<FARContext>();
        
        for (FARContext ctx : allContexts) {
            
            String key = ctx.poId + '_' + ctx.raId + '_' + ctx.role;
            
            System.debug('DELETE KEY = ' + key);
            System.debug(
                'REMAINING COUNT = ' +
                remainingCount.get(key)
            );
            System.debug(
                'CONTAINS KEY = ' +
                remainingCount.containsKey(key)
            );
            
            if (!remainingCount.containsKey(key)) {
                System.debug('ADDING TO REMOVE');
                toRemove.add(ctx);
            }
        }	

        if (toRemove.isEmpty()) return;

        // Collect IDs for bulk queries
        Set<Id> acrAccountIds = new Set<Id>();
        Set<Id> acrContactIds = new Set<Id>();
        Set<Id> ccrContactIds = new Set<Id>();
        Set<Id> aarAccountIds = new Set<Id>();

        for (FARContext ctx : toRemove) {
            if (ctx.poType == TYPE_BUSINESS
                    && ctx.raType == TYPE_INDIVIDUAL) {
                acrAccountIds.add(ctx.poId);
                if (ctx.raPersonContactId != null) {
                    acrContactIds.add(ctx.raPersonContactId);
                }
            } else if (ctx.poType == TYPE_INDIVIDUAL
                    && ctx.raType == TYPE_INDIVIDUAL) {
                if (ctx.poPersonContactId != null) {
                    ccrContactIds.add(ctx.poPersonContactId);
                }
                if (ctx.raPersonContactId != null) {
                    ccrContactIds.add(ctx.raPersonContactId);
                }
            } else if (ctx.poType == TYPE_INDIVIDUAL
                    && ctx.raType == TYPE_BUSINESS) {
                acrAccountIds.add(ctx.raId);
                if (ctx.poPersonContactId != null) {
                    acrContactIds.add(ctx.poPersonContactId);
                }
            } else if (ctx.poType == TYPE_BUSINESS
                    && ctx.raType == TYPE_BUSINESS) {
                aarAccountIds.add(ctx.poId);
                aarAccountIds.add(ctx.raId);
            }
        }

        Map<String, AccountContactRelation> existingACRs =
            queryExistingACRs(acrAccountIds, acrContactIds);
        Map<String, FinServ__ContactContactRelation__c> existingCCRs =
            queryExistingCCRs(ccrContactIds);
        Map<String, FinServ__AccountAccountRelation__c> existingAARs =
            queryExistingAARs(aarAccountIds);

        Map<Id, AccountContactRelation> acrToUpdateMap =
            new Map<Id, AccountContactRelation>();
        Map<Id, AccountContactRelation> acrToDeleteMap =
            new Map<Id, AccountContactRelation>();
        Map<Id, FinServ__ContactContactRelation__c> ccrToDeleteMap =
            new Map<Id, FinServ__ContactContactRelation__c>();
        Map<Id, FinServ__AccountAccountRelation__c> aarToDeleteMap =
            new Map<Id, FinServ__AccountAccountRelation__c>();
        List<String> errors = new List<String>();

        for (FARContext ctx : toRemove) {
            String roleLabel  = ctx.role;
            Id     contRoleId = contRoleMap.get(roleLabel);
            Id     acctRoleId = acctRoleMap.get(roleLabel);

            // AC9/AC10: Business PO + Individual RA
            if (ctx.poType == TYPE_BUSINESS
                    && ctx.raType == TYPE_INDIVIDUAL) {
                if (ctx.raPersonContactId == null) continue;
                AccountContactRelation acr = existingACRs.get(
                    ctx.poId + '_' + ctx.raPersonContactId
                );
                if (acr != null) {
                    
                   
                    System.debug('ROLE TO REMOVE = ' + roleLabel);
                    System.debug('ACR ID = ' + acr.Id);
                    System.debug('CURRENT ROLES = ' + acr.Roles);


                    String updated = removeRole(acr.Roles, roleLabel);

                    System.debug('UPDATED ROLES = ' + updated);
                    if (String.isBlank(updated)) {

                        System.debug(
                            'NO ROLES LEFT - MARKING ACR FOR DELETE'
                        );
						System.debug('ACR DELETE ID = ' + acr.Id);
                        acrToDeleteMap.put(acr.Id, acr);
                    } else {
	
                        System.debug(
                            'UPDATING ACR WITH ROLES = ' + updated
                        );

                        AccountContactRelation acrUpdate =
                            new AccountContactRelation();
                        
                        acrUpdate.Id = acr.Id;
                        acrUpdate.Roles = updated;
                        
                        System.debug('MARKING ACR FOR UPDATE');
                        System.debug('ADDING ACR TO UPDATE MAP');
                        
                        acrToUpdateMap.put(acrUpdate.Id, acrUpdate);
                    }
                }

            // AC9/AC10: Individual PO + Individual RA
            } else if (ctx.poType == TYPE_INDIVIDUAL
                    && ctx.raType == TYPE_INDIVIDUAL) {
                if (ctx.raPersonContactId == null
                        || ctx.poPersonContactId == null) continue;
                String key = ctx.raPersonContactId
                    + '_' + ctx.poPersonContactId
                    + '_' + contRoleId;
                FinServ__ContactContactRelation__c ccr =
                    existingCCRs.get(key);
                if (ccr != null) ccrToDeleteMap.put(ccr.Id, ccr);

            // AC9/AC10: Individual PO + Business RA
           /* } else if (ctx.poType == TYPE_INDIVIDUAL
                    && ctx.raType == TYPE_BUSINESS) {
                if (ctx.poPersonContactId == null) continue;
                AccountContactRelation acr = existingACRs.get(
                    ctx.raId + '_' + ctx.poPersonContactId
                );
                if (acr != null) {
                    String updated = removeRole(acr.Roles, roleLabel);
                    if (String.isBlank(updated)) {
                        acrToDeleteMap.put(acr.Id, acr);
                    } else {
                        acr.Roles = updated;
                        acrToUpdateMap.put(acr.Id, acr);
                    }
                } */

                    } else if (ctx.poType == TYPE_INDIVIDUAL
                               && ctx.raType == TYPE_BUSINESS) {
                                   
                                   if (ctx.poPersonContactId == null) continue;
                                   
                                   System.debug('EXISTING ACR KEYS = ' + existingACRs.keySet());

                                   String acrKey =
                                       ctx.raId + '_' + ctx.poPersonContactId;
                                   
                                   System.debug('LOOKUP KEY = ' + acrKey);
                                   
                                   System.debug('ACR KEY LOOKUP = ' + acrKey);
                                   System.debug('AVAILABLE ACR KEYS = ' + existingACRs.keySet());
                                   
                                   AccountContactRelation acr =
                                       existingACRs.get(acrKey);
                                   
                                   System.debug('ACR FOUND = ' + acr);
                                   System.debug('FOUND ACR = ' + acr);
                                   
                                   if (acr != null) {
                                       
                                       System.debug('ROLE TO REMOVE = ' + roleLabel);
                                       System.debug('CURRENT ROLES = ' + acr.Roles);
                                       
                                       String updated =
                                           removeRole(acr.Roles, roleLabel);
                                       
                                       System.debug('UPDATED ROLES = ' + updated);
                                       
                                       if (String.isBlank(updated)) {
                                           
                                           System.debug('MARKING ACR FOR DELETE');
                                           System.debug('ACR DELETE ID = ' + acr.Id);
                                           
                                           acrToDeleteMap.put(acr.Id, acr);
                                           
                                       } else {
                                           
                                           AccountContactRelation acrUpdate =
                                               new AccountContactRelation();
                                           
                                           acrUpdate.Id = acr.Id;
                                           acrUpdate.Roles = updated;
                                           
                                           System.debug('MARKING ACR FOR UPDATE');
                                           System.debug('ADDING ACR TO UPDATE MAP');
                                           
                                           acrToUpdateMap.put(acrUpdate.Id, acrUpdate);
                                       }
                                   }
                               

            // AC9/AC10: Business PO + Business RA
            } else if (ctx.poType == TYPE_BUSINESS
                    && ctx.raType == TYPE_BUSINESS) {
                String key = ctx.poId + '_' + ctx.raId
                    + '_' + acctRoleId;
                FinServ__AccountAccountRelation__c aar =
                    existingAARs.get(key);
                if (aar != null) aarToDeleteMap.put(aar.Id, aar);
            }
        }

        // Execute DML
        AccountContactRelationTriggerHandler.suppressTrigger = true;
        try {
            System.debug(
                'ACR UPDATE COUNT = ' +
                acrToUpdateMap.size()
            );
            if (!acrToUpdateMap.isEmpty()) {
                collectErrors(
                    Database.update(acrToUpdateMap.values(), false),
                    'ACR Role Remove', errors
                );
            }
            System.debug(
                'ACR DELETE COUNT = ' +
                acrToDeleteMap.size()
            );
            if (!acrToDeleteMap.isEmpty()) {
                collectDeleteErrors(
                    Database.delete(acrToDeleteMap.values(), false),
                    'ACR Delete', errors
                );
            }
        } finally {
            AccountContactRelationTriggerHandler.suppressTrigger = false;
        }

        if (!ccrToDeleteMap.isEmpty()) {
            collectDeleteErrors(
                Database.delete(ccrToDeleteMap.values(), false),
                'CCR Delete', errors
            );
        }
        if (!aarToDeleteMap.isEmpty()) {
            collectDeleteErrors(
                Database.delete(aarToDeleteMap.values(), false),
                'AAR Delete', errors
            );
        }

        if (!errors.isEmpty()) {
            sendErrorEmail(String.join(errors, '\n'));
        }
    }

    // =========================================================
    // BUSINESS FILTER
    // =========================================================
    private List<FinServ__FinancialAccountRole__c> applyBusinessFilter(
        List<FinServ__FinancialAccountRole__c> records
    ) {
        List<FinServ__FinancialAccountRole__c> result =
            new List<FinServ__FinancialAccountRole__c>();
        for (FinServ__FinancialAccountRole__c far : records) {
            if (isQualifiedFA(far.FinServ__FinancialAccount__r)) {
                result.add(far);
            }
        }
        return result;
    }

    private Boolean isQualifiedFA(FinServ__FinancialAccount__c fa) {
        return fa != null
            && fa.RecordType.DeveloperName == DEPOSIT_RT_DEV_NAME
            && QUALIFYING_SPECIAL_CASES.contains(fa.BKU_Special_Case__c);
    }

    // =========================================================
    // QUERY HELPERS
    // =========================================================
    private Map<String, AccountContactRelation> queryExistingACRs(
        Set<Id> accountIds, Set<Id> contactIds
    ) {
        Map<String, AccountContactRelation> result =
            new Map<String, AccountContactRelation>();
        if (accountIds.isEmpty() || contactIds.isEmpty()) return result;
        for (AccountContactRelation acr : [
            SELECT Id, AccountId, ContactId, Roles
            FROM AccountContactRelation
            WHERE AccountId IN :accountIds
              AND ContactId  IN :contactIds
        ]) {
            result.put(acr.AccountId + '_' + acr.ContactId, acr);
        }
        return result;
    }

    private Map<String, FinServ__ContactContactRelation__c> queryExistingCCRs(
        Set<Id> contactIds
    ) {
        Map<String, FinServ__ContactContactRelation__c> result =
            new Map<String, FinServ__ContactContactRelation__c>();
        if (contactIds.isEmpty()) return result;
        for (FinServ__ContactContactRelation__c ccr : [
            SELECT Id,
                   FinServ__Contact__c,
                   FinServ__RelatedContact__c,
                   FinServ__Role__c
            FROM FinServ__ContactContactRelation__c
            WHERE FinServ__Contact__c        IN :contactIds
              AND FinServ__RelatedContact__c IN :contactIds
        ]) {
            result.put(
                ccr.FinServ__Contact__c
                + '_' + ccr.FinServ__RelatedContact__c
                + '_' + ccr.FinServ__Role__c,
                ccr
            );
        }
        return result;
    }

