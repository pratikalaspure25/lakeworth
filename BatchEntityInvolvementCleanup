public with sharing class BatchEntityInvolvementCleanup implements Database.Batchable<SObject>, Database.Stateful {
 
    // ---- Configuration (edit to match your org's schema) ----
    private static final String ROLE_OBJECT          = 'LLC_BI__Legal_Entities__c';
    private static final String ACCOUNT_LOOKUP_FIELD  = 'LLC_BI__Account__c';
    private static final String DEPOSIT_RT_DEVNAME    = 'Deposit_Account';
    private static final String LOAN_RT_DEVNAME       = 'Loan_Account';
    private static final String BORROWER_TYPE_FIELD   = 'Borrower_Type__c';
 
    private static final Set<String> EXCLUDED_BORROWER_TYPES = new Set<String>{
        'Related Entity',
        'Other - Authorized Signer',
        'Affiliate',
        'Seller',
        'Key Role Employee',
        'Unassigned'
    };
 
    // Stateful counters for the summary email in finish()
    public Integer totalQueried   = 0;
    public Integer totalDeleted   = 0;
    public Integer totalFailed    = 0;
    public List<String> failureDetails = new List<String>();
 
    public Database.QueryLocator start(Database.BatchableContext bc) {
        Date cutoff = System.today().addDays(-5);
 
        String excludedList = '(\'' + String.join(new List<String>(EXCLUDED_BORROWER_TYPES), '\',\'') + '\')';
 
        String query =
            'SELECT Id, Name, ' + ACCOUNT_LOOKUP_FIELD + ', ' +
            ACCOUNT_LOOKUP_FIELD.removeEnd('__c') + '__r.RecordType.DeveloperName, ' +
            BORROWER_TYPE_FIELD + ', LastModifiedDate ' +
            'FROM ' + ROLE_OBJECT + ' ' +
            'WHERE LastModifiedDate <= :cutoff ' +
            'AND ( ' +
            '  ' + ACCOUNT_LOOKUP_FIELD.removeEnd('__c') + '__r.RecordType.DeveloperName = \'' + DEPOSIT_RT_DEVNAME + '\' ' +
            '  OR ' +
            '  ( ' + ACCOUNT_LOOKUP_FIELD.removeEnd('__c') + '__r.RecordType.DeveloperName = \'' + LOAN_RT_DEVNAME + '\' ' +
            '    AND ' + BORROWER_TYPE_FIELD + ' NOT IN ' + excludedList + ' ' +
            '  ) ' +
            ')';
 
        return Database.getQueryLocator(query);
    }
 
    public void execute(Database.BatchableContext bc, List<SObject> scope) {
        totalQueried += scope.size();
 
        // 1. Write an audit trail BEFORE deleting (best practice for financial data)
        List<Entity_Involvement_Deletion_Log__c> logs = new List<Entity_Involvement_Deletion_Log__c>();
        for (SObject rec : scope) {
            logs.add(new Entity_Involvement_Deletion_Log__c(
                Original_Record_Id__c   = rec.Id,
                Deletion_Reason__c      = 'Stale role - automated weekly cleanup',
                Deleted_Date__c         = System.now(),
                Related_Account_Id__c   = (Id) rec.get(ACCOUNT_LOOKUP_FIELD)
            ));
        }
        if (!logs.isEmpty()) {
            Database.insert(logs, false); // don't let a log failure block the delete
        }
 
        // 2. Bulk delete, allowing partial success so one bad record
        //    doesn't fault the whole chunk
        List<Database.DeleteResult> results = Database.delete(scope, false);
 
        for (Integer i = 0; i < results.size(); i++) {
            if (results[i].isSuccess()) {
                totalDeleted++;
            } else {
                totalFailed++;
                for (Database.Error err : results[i].getErrors()) {
                    failureDetails.add(scope[i].Id + ': ' + err.getStatusCode() + ' - ' + err.getMessage());
                }
            }
        }
    }
 
    public void finish(Database.BatchableContext bc) {
        // Email a run summary to the job owner / admin group
        AsyncApexJob job = [
            SELECT Id, Status, NumberOfErrors, JobItemsProcessed, TotalJobItems, CreatedBy.Email
            FROM AsyncApexJob
            WHERE Id = :bc.getJobId()
        ];
 
        String body =
            'Entity Involvement Cleanup Batch finished.\n\n' +
            'Records evaluated : ' + totalQueried + '\n' +
            'Records deleted   : ' + totalDeleted + '\n' +
            'Records failed    : ' + totalFailed + '\n\n' +
            (failureDetails.isEmpty() ? '' : ('Failures:\n' + String.join(failureDetails, '\n')));
 
        Messaging.SingleEmailMessage mail = new Messaging.SingleEmailMessage();
        mail.setToAddresses(new String[]{ job.CreatedBy.Email });
        mail.setSubject('Entity Involvement Cleanup - Run Summary (' + System.today().format() + ')');
        mail.setPlainTextBody(body);
        if (!Test.isRunningTest()) {
            Messaging.sendEmail(new Messaging.SingleEmailMessage[]{ mail });
        }
    }
}
