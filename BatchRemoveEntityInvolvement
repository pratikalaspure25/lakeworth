public with sharing class BatchRemoveEntityInvolvement implements Database.Batchable<SObject> {
 
    private static final String DEPOSIT_RT_DEVNAME = 'Deposit_Account';
    private static final String LOAN_RT_DEVNAME     = 'Loan_Account';
 
    public Database.QueryLocator start(Database.BatchableContext bc) {
        Datetime cutoff = System.now().addDays(-5);
 
        List<String> excludedBorrowerTypes = new List<String>{
            'Related Entity',
            'Other - Authorized Signer',
            'Affiliate',
            'Seller',
            'Key Role Employee',
            'Unassigned'
        };
 
        return Database.getQueryLocator([
            SELECT Id
            FROM LLC_BI__Legal_Entities__c
            WHERE LastModifiedDate <= :cutoff
            AND (
                Account__r.RecordType.DeveloperName = :DEPOSIT_RT_DEVNAME
                OR (
                    Account__r.RecordType.DeveloperName = :LOAN_RT_DEVNAME
                    AND Borrower_Type__c NOT IN :excludedBorrowerTypes
                )
            )
        ]);
    }
 
    public void execute(Database.BatchableContext bc, List<SObject> scope) {
        Database.delete(scope, false);
    }
 
    public void finish(Database.BatchableContext bc) {
    }
}
