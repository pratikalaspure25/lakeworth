public without sharing class BatchRemoveEntityInvolvement
implements Database.Batchable<SObject> {

    @TestVisible
    private static final Integer STALE_THRESHOLD_DAYS = 5;

    @TestVisible
    private static final Set<String> EXCLUDED_BORROWER_TYPES = new Set<String>{
        'Related Entity',
        'Other - Authorized Signer',
        'Affiliate',
        'Seller',
        'Key Role Employee',
        'Unassigned'
    };

    public Database.QueryLocator start(Database.BatchableContext bc) {

        Datetime cutoff = System.now().addDays(-STALE_THRESHOLD_DAYS);

        return Database.getQueryLocator([
            SELECT Id
            FROM LLC_BI__Legal_Entities__c
            WHERE LastModifiedDate <= :cutoff
            AND (
                LLC_BI__Deposit__c != NULL
                OR (
                    LLC_BI__Loan__c != NULL
                    AND LLC_BI__Borrower_Type__c NOT IN :EXCLUDED_BORROWER_TYPES
                )
            )
        ]);
    }

    public void execute(Database.BatchableContext bc, List<SObject> scope) {
        Database.delete(scope, false);
    }

    public void finish(Database.BatchableContext bc) {
    }
}
