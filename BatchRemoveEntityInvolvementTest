@isTest
private class BatchRemoveEntityInvolvementTest {
 
    @TestSetup
    static void makeData() {
        Account acct = new Account(Name = 'Test Account');
        insert acct;
 
        // TODO: add any other required fields found on LLC_BI__Deposit__c
        LLC_BI__Deposit__c depositRec = new LLC_BI__Deposit__c(Name = 'Test Deposit');
        insert depositRec;
 
        // TODO: add any other required fields found on LLC_BI__Loan__c
        LLC_BI__Loan__c loanRec = new LLC_BI__Loan__c(Name = 'Test Loan');
        insert loanRec;
 
        List<LLC_BI__Legal_Entities__c> roles = new List<LLC_BI__Legal_Entities__c>();
 
        // 1. Stale Deposit role -> should be deleted (AC1)
        roles.add(new LLC_BI__Legal_Entities__c(
            Name = 'Stale Deposit Role',
            LLC_BI__Account__c = acct.Id,
            LLC_BI__Deposit__c = depositRec.Id
        ));
 
        // 2. Stale Loan role, non-excluded Borrower Type -> should be deleted (AC2)
        roles.add(new LLC_BI__Legal_Entities__c(
            Name = 'Stale Loan Role - Guarantor',
            LLC_BI__Account__c = acct.Id,
            LLC_BI__Loan__c = loanRec.Id,
            LLC_BI__Borrower_Type__c = 'Guarantor'
        ));
 
        // 3. Stale Loan role, EXCLUDED Borrower Type -> should be kept
        roles.add(new LLC_BI__Legal_Entities__c(
            Name = 'Stale Loan Role - Affiliate',
            LLC_BI__Account__c = acct.Id,
            LLC_BI__Loan__c = loanRec.Id,
            LLC_BI__Borrower_Type__c = 'Affiliate'
        ));
 
        // 4. Fresh Deposit role (not yet stale) -> should be kept
        roles.add(new LLC_BI__Legal_Entities__c(
            Name = 'Fresh Deposit Role',
            LLC_BI__Account__c = acct.Id,
            LLC_BI__Deposit__c = depositRec.Id
        ));
 
        insert roles;
 
        // Backdate LastModifiedDate on records 1-3 to simulate "6 days old".
        // Test.setCreatedDate sets both CreatedDate and LastModifiedDate,
        // and only works inside a test method - this is the ONLY supported
        // way to simulate an aged record; it cannot be done on real data
        // via anonymous Apex, UI, or Data Loader.
        Datetime staleDate = Datetime.now().addDays(-6);
        Test.setCreatedDate(roles[0].Id, staleDate);
        Test.setCreatedDate(roles[1].Id, staleDate);
        Test.setCreatedDate(roles[2].Id, staleDate);
        // roles[3] left at today's date -> "fresh", must survive
    }
 
    @isTest
    static void testBatchDeletesOnlyMatchingRoles() {
        Test.startTest();
        Database.executeBatch(new BatchRemoveEntityInvolvement(), 200);
        Test.stopTest();
 
        Set<String> remainingNames = new Set<String>();
        for (LLC_BI__Legal_Entities__c r : [SELECT Name FROM LLC_BI__Legal_Entities__c]) {
            remainingNames.add(r.Name);
        }
 
        System.assert(!remainingNames.contains('Stale Deposit Role'),
            'Stale deposit role should have been deleted per AC1');
        System.assert(!remainingNames.contains('Stale Loan Role - Guarantor'),
            'Stale loan role with non-excluded Borrower Type should have been deleted per AC2');
        System.assert(remainingNames.contains('Stale Loan Role - Affiliate'),
            'Stale loan role with excluded Borrower Type must be kept');
        System.assert(remainingNames.contains('Fresh Deposit Role'),
            'Recently modified role must be kept');
    }
}
